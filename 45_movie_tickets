#This now is a function and checks how old they are if they are under 13 their ticket costs 8$ if older than 13 then it costs 12$ if 65 or older then it costs ten.
def movie(age):
    if age < 13:
        print('your ticket costs $8')
    elif age >= 65:
        print('your ticket costs $10')
    elif age >= 13:
        print('your ticket costs $12')

movie(45)
